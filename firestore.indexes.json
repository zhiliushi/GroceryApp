{
  "indexes": [
    {
      "_comment": "Legacy grocery_items — status + expiry queries (pre-refactor, kept until migration complete)",
      "collectionGroup": "grocery_items",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "expiryDate", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "grocery_items",
      "queryScope": "COLLECTION_GROUP",
      "fields": [
        { "fieldPath": "status", "order": "ASCENDING" },
        { "fieldPath": "expiryDate", "order": "ASCENDING" }
      ]
    },

    {
      "_comment": "Refactor Phase 2 — catalog_entries (global collection)",
      "collectionGroup": "catalog_entries",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "user_id", "order": "ASCENDING" },
        { "fieldPath": "barcode", "order": "ASCENDING" }
      ]
    },
    {
      "collectionGroup": "catalog_entries",
      "queryScope": "COLLECTION",
      "fields": [
        { "fieldPath": "user_id", "order": "ASCENDING" },
        { "fieldPath": "name_norm", "order": "ASCENDING" }
