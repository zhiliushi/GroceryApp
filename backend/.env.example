# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=path/to/serviceAccountKey.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# API Configuration
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8081"]

# Open Food Facts API
OPEN_FOOD_FACTS_API=https://world.openfoodfacts.org/api/v2

# AI Service (optional — Ollama local or OpenAI-compatible endpoint)
# AI_SERVICE_URL=http://localhost:11434
# AI_MODEL_NAME=llama3.2

# OCR — Receipt scanning (optional, Tesseract always available as fallback)
# Google Cloud Vision: enable Vision API in GCP console, uses Firebase service account
# GOOGLE_VISION_API_KEY=
# Mindee: get API key from https://platform.mindee.com
# MINDEE_API_KEY=
# Mistral AI: LLM fallback when regex parsing fails (free tier: 1M tokens/month)
# Get API key from https://console.mistral.ai
# MISTRAL_API_KEY=

# Error tracking — Sentry free tier (https://sentry.io). Leave empty to disable.
# Get the backend project DSN at sentry.io > Settings > Projects > <python project> > Client Keys.
# SENTRY_DSN=
