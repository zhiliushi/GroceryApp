# Firebase client-side config (public keys, safe to commit)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Error tracking — Sentry free tier (https://sentry.io). Leave empty to disable.
# Get the frontend project DSN at sentry.io > Settings > Projects > <react project> > Client Keys.
# Note: VITE_* env vars are baked into the SPA bundle; the DSN is a public key, safe to expose.
# VITE_SENTRY_DSN=
