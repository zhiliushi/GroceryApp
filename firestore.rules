rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -----------------------------------------------------------------------
    // Helper functions
    // -----------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if requesting user is in the same household as the document owner.
    function isHouseholdMember(userId) {
      let requesterProfile = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let ownerProfile = get(/databases/$(database)/documents/users/$(userId)).data;
      return requesterProfile.household_id != null
          && requesterProfile.household_id == ownerProfile.household_id;
    }

    // Owner OR household member
    function canAccess(userId) {
      return isOwner(userId) || (isAuthenticated() && isHouseholdMember(userId));
    }

    function hasString(field) {
      return field in request.resource.data
          && request.resource.data[field] is string
          && request.resource.data[field].size() > 0;
    }

    function hasNumber(field) {
      return field in request.resource.data
          && request.resource.data[field] is number;
    }

    // -----------------------------------------------------------------------
    // User profile
    // -----------------------------------------------------------------------

    match /users/{userId} {
      allow read: if isOwner(userId) || (isAuthenticated() && isHouseholdMember(userId));
      allow create: if isOwner(userId) && hasString('email');
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // Inventory items — household members can read + update (shared editing)
      match /grocery_items/{itemId} {
        allow read: if canAccess(userId);
        allow create: if isOwner(userId) && hasString('name') && hasString('status')
                      && request.resource.data.status in ['active', 'consumed', 'expired', 'discarded'];
        allow update: if canAccess(userId)
                      && (!('status' in request.resource.data)
                          || request.resource.data.status in ['active', 'consumed', 'expired', 'discarded']);
        allow delete: if isOwner(userId);
      }

      // Shopping lists — household shared
      match /shopping_lists/{listId} {
        allow read: if canAccess(userId);
        allow create: if isOwner(userId) && hasString('name');
        allow update: if canAccess(userId);
        allow delete: if isOwner(userId);

        match /items/{itemId} {
          allow read: if canAccess(userId);
          allow create: if canAccess(userId);
          allow update: if canAccess(userId);
          allow delete: if canAccess(userId);
        }
      }

      // Analytics — personal only
      match /analytics/{eventId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // Price records — household can read (shared comparison)
      match /price_records/{recordId} {
        allow read: if canAccess(userId);
        allow create: if isOwner(userId) && hasString('barcode') && hasNumber('price');
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // Receipt scans — personal
      match /receipt_scans/{scanId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if false;
      }

      // Stores — household shared
      match /stores/{storeId} {
        allow read: if canAccess(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /sync_meta/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Households — members can read, backend manages writes
    match /households/{householdId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Invitations — authenticated read, backend writes
    match /invitations/{code} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // App config — public read
    match /app_config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Products — authenticated read
    match /products/{barcode} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Contributed products
    match /contributed_products/{barcode} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Product disputes
    match /product_disputes/{disputeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Foodbanks — public read
    match /foodbanks/{foodbankId} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Refactor Phase 2 — catalog + purchases + countries
    // -----------------------------------------------------------------------

    // Catalog entries — global collection keyed by `{user_id}__{name_norm}`.
    // Owner-only read/write. Admin bypass via Admin SDK (which ignores rules).
    match /catalog_entries/{entryId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;

      // Create: doc ID must match `{uid}__{name_norm}` — enforces per-user uniqueness at the storage layer
      allow create: if isAuthenticated()
                    && request.resource.data.user_id == request.auth.uid
                    && entryId == request.auth.uid + '__' + request.resource.data.name_norm
                    && request.resource.data.name_norm is string
                    && request.resource.data.name_norm.size() > 0;

      // Update: only the owner
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid;

      // Delete: only if no active purchases (mirrors backend invariant)
      allow delete: if isAuthenticated()
                    && resource.data.user_id == request.auth.uid
                    && resource.data.active_purchases == 0;
    }

    // Purchase events — subcollection under users/{uid}/purchases
    match /users/{userId}/purchases/{eventId} {
      allow read: if canAccess(userId);
      allow create: if isOwner(userId)
                    && request.resource.data.catalog_name_norm is string
                    && request.resource.data.status in ['active', 'used', 'thrown', 'transferred'];
      allow update: if canAccess(userId)
                    && (!('status' in request.resource.data)
                        || request.resource.data.status in ['active', 'used', 'thrown', 'transferred']);
      allow delete: if isOwner(userId);
    }

    // Reminders — subcollection under users/{uid}/reminders
    match /users/{userId}/reminders/{reminderId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId);       // user dismisses reminders
      allow create, delete: if false;         // scheduler (Admin SDK) only
    }

    // Cache + insights — personal
    match /users/{userId}/cache/{docId} {
      allow read: if isOwner(userId);
      allow write: if false;                  // backend only
    }

    match /users/{userId}/insights/{insightId} {
      allow read: if isOwner(userId);
      allow update, delete: if isOwner(userId);
      allow create: if false;                 // scheduler/backend only
    }

    // Countries — public read (GS1 prefix lookup)
    match /countries/{countryCode} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
